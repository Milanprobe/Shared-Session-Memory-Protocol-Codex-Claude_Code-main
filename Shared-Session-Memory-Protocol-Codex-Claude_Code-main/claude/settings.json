{
  "env": {
    "BLACK_CACHE_DIR": "",
    "PYTEST_ADDOPTS": "--basetemp={PATH} to Temp/claude/driver--project-name/pytest -o cache_dir={PATH} to Temp/claude/driver--project-name/pytest-cache",
    "TEMP": "DRIVER:\\Temp\\claude\\driver--project-name",
    "TMP": "DRIVER:\\Temp\\claude\\driver--project-name",
    "TMPDIR": "DRIVER:\\Temp\\claude\\driver--project-name"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "{PATH} to powershell.exe -NoProfile -ExecutionPolicy Bypass -Command \"& (Join-Path ([Environment]::GetEnvironmentVariable('CLAUDE_PROJECT_DIR')) '.claude/hooks/inject-session-memory.ps1') -Client claude_code\"",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "{PATH} to powershell.exe -NoProfile -ExecutionPolicy Bypass -Command \"& (Join-Path ([Environment]::GetEnvironmentVariable('CLAUDE_PROJECT_DIR')) '.claude/hooks/inject-session-memory.ps1') -Client claude_code\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
