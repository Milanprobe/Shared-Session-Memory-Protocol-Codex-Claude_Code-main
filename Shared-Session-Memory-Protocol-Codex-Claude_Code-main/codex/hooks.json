{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "{PATH} to powershell.exe -NoProfile -ExecutionPolicy Bypass -File \"{PATH} to project/.codex/hooks/inject-session-memory.ps1\"",
            "timeout": 10,
            "statusMessage": "Loading project session receipt"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "{PATH} to powershell.exe -NoProfile -ExecutionPolicy Bypass -File \"{PATH} to project/.codex/hooks/inject-session-memory.ps1\"",
            "timeout": 10,
            "statusMessage": "Correlating latest project receipt"
          }
        ]
      }
    ]
  }
}
